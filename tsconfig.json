{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@procash-invoices/database": ["packages/database/dist/index.d.ts"],
      "@procash-invoices/database/server": ["packages/database/dist/server.d.ts"],
      "@procash-invoices/api-client": ["packages/api-client/dist/index.d.ts"],
      "@procash-invoices/document-templates": ["packages/document-templates/dist/index.d.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
