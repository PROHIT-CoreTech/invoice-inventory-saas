{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["apps/backend/src/**", "packages/database/dist/**", "packages/database/package.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/backend/api/index.ts"
    }
  ]
}
